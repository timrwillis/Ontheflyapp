{
  "name": "sandbox-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --skipLibCheck",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "migrate": "drizzle-kit migrate",
