    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@fastify/aws-lambda": "6.1.1",
    "@fastify/cors": "^10.1.0",
    "@fastify/multipart": "^9.3.0",
    "@fastify/swagger": "9.6.1",
    "@fastify/websocket": "11.2.0",
    "@neondatabase/serverless": "1.0.2",
    "better-auth": "1.4.5",
    "commander": "12.1.0",
    "drizzle-orm": "0.44.7",
    "fastify": "^5.7.1",
    "nanoid": "5.1.11",
    "pino-pretty": "13.1.3",
    "postgres": "3.4.9"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "drizzle-kit": "0.31.5",
    "esbuild": "0.27.4",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
